# App
NODE_ENV=development
PORT=5001

# Database
DB_HOST=localhost
DB_PORT=35432
DB_NAME=teamflow
DB_USER=teamflow
DB_PASSWORD=teamflow
DATABASE_URL=postgresql://teamflow:teamflow@localhost:35432/teamflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=36379
REDIS_URL=redis://localhost:36379
REDIS_UI_URL=http://localhost:35540

# Mail
SMTP_HOST=localhost
SMTP_PORT=31125
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@teamflow.local
MAILPIT_UI_URL=http://localhost:38025

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=10
EMAIL_VERIFICATION_EXPIRY_MINUTES=60
PASSWORD_RESET_EXPIRY_MINUTES=30
OAUTH_STATE_EXPIRY_SECONDS=600
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5001/api/auth/github/callback
NODE_ENV=development
